{
  "_comment": "Screens are yours. Each defines a universe (explicit ticker list, or {\"theme\": \"name\"} pulling from themes.json) and a filters object. The screener returns tickers that pass all filters with raw data — it does NOT rank, recommend, or pre-select. Empty 'screens' array means the section is omitted from the daily message.",
  "_supported_filters": {
    "marketCapMin": "minimum market cap, $ (e.g., 1000000000 = $1B)",
    "marketCapMax": "maximum market cap, $",
    "currentPriceMin": "minimum last price, $",
    "currentPriceMax": "maximum last price, $",
    "trailingPEMin": "minimum trailing P/E",
    "trailingPEMax": "maximum trailing P/E",
    "forwardPEMin": "minimum forward P/E",
    "forwardPEMax": "maximum forward P/E",
    "psRatioMax": "maximum P/S (trailing 12mo)",
    "pbRatioMax": "maximum P/B",
    "betaMax": "maximum 5y beta",
    "dividendYieldMin": "minimum dividend yield, decimal (0.025 = 2.5%)",
    "revenueGrowthMin": "minimum quarterly revenue growth, decimal (0.20 = 20%)",
    "profitMarginsMin": "minimum profit margin, decimal",
    "shortPercentOfFloatMax": "maximum short interest, decimal"
  },
  "_template_example": {
    "name": "example_lower_vol_value",
    "universe": ["TICKER1", "TICKER2", "TICKER3"],
    "filters": {
      "marketCapMin": 1000000000,
      "trailingPEMax": 25,
      "betaMax": 1.2,
      "dividendYieldMin": 0.015
    }
  },
  "_template_with_theme": {
    "name": "example_theme_screen",
    "universe": {"theme": "ai_infra_hardware"},
    "filters": {
      "currentPriceMin": 10
    }
  },
  "screens": [
    {
      "name": "ai_infra_value_lens",
      "_note": "STARTER screen — your own tickers from themes.json with conservative valuation/risk thresholds you can tighten or loosen. Edit/delete freely.",
      "universe": {"theme": "ai_infra_hardware"},
      "filters": {
        "marketCapMin": 5000000000,
        "trailingPEMax": 50,
        "betaMax": 2.5,
        "psRatioMax": 30
      }
    },
    {
      "name": "saas_with_topline_growth",
      "_note": "STARTER — enterprise SaaS names you already follow, filtered for revenue growth + reasonable P/S.",
      "universe": {"theme": "enterprise_saas"},
      "filters": {
        "revenueGrowthMin": 0.10,
        "psRatioMax": 15
      }
    }
  ]
}
